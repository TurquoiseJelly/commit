{
  "name": "flatpress",
  "version": "1.0.0",
  "type": "module",
  "description": "A lightweight, Git-backed, Markdown-driven static site CMS.",
  "scripts": {
    "build": "node src/build.js",
    "dev": "node scripts/dev.js",
    "validate": "node src/validate.js",
    "new-post": "bash scripts/new-post.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "markdown-it": "14.1.1",
    "markdown-it-highlightjs": "4.2.0",
    "gray-matter": "4.0.3",
    "handlebars": "4.7.8",
    "sanitize-html": "2.13.1",
    "js-yaml": "4.1.1"
  },
  "devDependencies": {
    "chokidar": "4.0.3",
    "livereload": "0.9.3"
  }
}
